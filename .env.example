PORT=4000
JWT_SECRET=your_secret_here
SALT_ROUNDS=10

# Use either DATABASE_URL or the individual fields below.
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/blogapi

# Optional alternative to DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blogapi
DB_USER=postgres
DB_PASSWORD=your_password

# Optional upload folder
UPLOAD_DIR=uploads
